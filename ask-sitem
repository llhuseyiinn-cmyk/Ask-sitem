<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<title>Hüseyin ❤️ Sude</title>

<style>
body {
    margin: 0;
    font-family: Arial;
    text-align: center;
    background: linear-gradient(to right, #ff758c, #ff7eb3);
    color: white;
}

/* Şifre ekranı */
#login {
    position: fixed;
    width: 100%;
    height: 100%;
    background: #ff4b5c;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    z-index: 999;
}

/* Kalpler */
.heart {
    position: fixed;
    bottom: -10px;
    animation: float 5s linear infinite;
}
@keyframes float {
    to { transform: translateY(-100vh); }
}

/* Galeri */
.gallery img {
    width: 200px;
    border-radius: 15px;
    margin: 10px;
}

/* Buton */
button {
    padding: 12px 20px;
    border-radius: 10px;
    border: none;
    cursor: pointer;
}
</style>

</head>

<body>

<div id="login">
    <h2>Şifreyi gir 💖</h2>
    <input type="password" id="pass">
    <br><br>
    <button onclick="giris()">Giriş</button>
</div>

<h1>Hüseyin ❤️ Sude</h1>
<p id="type"></p>
<p id="counter"></p>
<p id="countdown"></p>

<h2>Anılarımız 📸</h2>
<div class="gallery">
<img src="foto1.jpg">
<img src="foto2.jpg">
<img src="foto3.jpg">
</div>

<h2>Biz 🎥</h2>
<video width="300" controls>
<source src="video.mp4">
</video>

<h2>İlk Buluşma 📍</h2>
<iframe src="https://www.google.com/maps?q=izmir&output=embed" width="300" height="200"></iframe>

<br><br>
<button onclick="mesaj()">Mesaj 💌</button>
<button onclick="teklif()">Sürpriz 💍</button>

<p id="yazi"></p>

<audio autoplay loop>
<source src="muzik.mp3">
</audio>

<script>

// Şifre
function giris() {
    let sifre = document.getElementById("pass").value;
    if(sifre === "1201") {
        document.getElementById("login").style.display = "none";
    } else {
        alert("Yanlış şifre 😄");
    }
}

// Yazı efekti
let text = "Sen benim en güzel hikayemsin...";
let i=0;
function yaz(){
if(i<text.length){
document.getElementById("type").innerHTML += text[i];
i++;
setTimeout(yaz,50);
}}
yaz();

// Sayaç
setInterval(()=>{
let start=new Date("2026-01-12");
let now=new Date();
let diff=now-start;

let d=Math.floor(diff/86400000);
let h=Math.floor(diff/3600000)%24;
let m=Math.floor(diff/60000)%60;

document.getElementById("counter").innerHTML=
d+" gün "+h+" saat "+m+" dakika ❤️";
},1000);

// Geri sayım (yıl dönümü)
setInterval(()=>{
let target=new Date("2027-01-12");
let now=new Date();
let diff=target-now;

let d=Math.floor(diff/86400000);
document.getElementById("countdown").innerHTML=
"Yıl dönümüne "+d+" gün kaldı 🎂";
},1000);

// Kalpler
setInterval(()=>{
let h=document.createElement("div");
h.className="heart";
h.innerHTML="❤️";
h.style.left=Math.random()*100+"vw";
document.body.appendChild(h);
setTimeout(()=>h.remove(),5000);
},300);

// Mesaj
function mesaj(){
document.getElementById("yazi").innerHTML=
"Sude... seni her şeyden çok seviyorum ❤️";
}

// Teklif
function teklif(){
document.getElementById("yazi").innerHTML=
"Benimle bir ömür geçirir misin? 💍";
}

</script>

</body>
</html>
<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<title>Site Girişi</title>
<script>
function kontrolEt() {
    const sifre = document.getElementById("sifre").value;
    if(sifre === "120126") {
        alert("Giriş başarılı! ❤️");
        // Ana siteye yönlendirme yapabilirsiniz
        window.location.href = "anasayfa.html"; 
    } else {
        alert("Şifre yanlış 😢");
    }
}
</script>
</head>
<body>
<h2>Siteye Giriş</h2>
<input type="password" id="sifre" placeholder="Şifreyi gir">
<button onclick="kontrolEt()">Giriş Yap</button>
</body>
</html>
