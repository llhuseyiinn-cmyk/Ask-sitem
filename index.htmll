<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hüseyin & Sude | Sonsuza Dek</title>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root { --primary: #ff4d6d; --secondary: #ff8fa3; --dark: #590d22; }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Poppins', sans-serif; background: #fff0f3; color: var(--dark); overflow-x: hidden; }

        /* --- ŞİFRE EKRANI --- */
        #login-screen {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: var(--dark); z-index: 1000; display: flex;
            flex-direction: column; align-items: center; justify-content: center; color: white;
        }
        input { padding: 12px; border-radius: 25px; border: none; margin: 15px; text-align: center; font-size: 1.2rem; }
        button { padding: 10px 30px; border-radius: 25px; border: none; background: var(--primary); color: white; cursor: pointer; }

        /* --- ANA İÇERİK --- */
        #main-content { display: none; text-align: center; }
        header { height: 100vh; display: flex; flex-direction: column; justify-content: center; background: radial-gradient(circle, #ff8fa3 0%, #fff0f3 100%); }
        h1 { font-family: 'Dancing Script', cursive; font-size: 4rem; color: var(--primary); margin-bottom: 20px; }
        
        /* --- SAYAÇ --- */
        .timer-container { padding: 50px 20px; background: white; margin: 20px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
        #timer { font-size: 1.5rem; font-weight: 600; color: var(--primary); }

        /* --- GALERİ --- */
        .gallery { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 15px; padding: 20px; }
        .gallery img { width: 100%; border-radius: 15px; transition: 0.3s; box-shadow: 0 5px 15px rgba(0,0,0,0.1); }

        /* --- TEKLİF --- */
        .proposal { padding: 80px 20px; background: var(--primary); color: white; }
        .btn-yes { font-size: 2rem; padding: 15px 40px; background: white; color: var(--primary); border-radius: 50px; border: none; margin-top: 20px; animation: pulse 1.5s infinite; }

        /* --- ANİMASYONLAR --- */
        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.1); } 100% { transform: scale(1); } }
        .heart { position: fixed; color: var(--primary); pointer-events: none; z-index: 999; animation: fly 4s linear forwards; }
        @keyframes fly { to { transform: translateY(-100vh) rotate(360deg); opacity: 0; } }
    </style>
</head>
<body>

    <!-- Şifre Ekranı -->
    <div id="login-screen">
        <h2>Aşkımızın Tarihi? ❤️</h2>
        <input type="password" id="pass" placeholder="GGAA26">
        <button onclick="checkPass()">Giriş Yap</button>
    </div>

    <!-- Müzik -->
    <audio id="bgMusic" loop>
        <source src="music.mp3" type="audio/mpeg">
    </audio>

    <div id="main-content">
        <header>
            <h1 id="typing-text"></h1>
            <p>Karacasu'da başlayan bu masal...</p>
        </header>

        <section class="timer-container">
            <h3>Birlikte Geçen Zamanımız</h3>
            <div id="timer">Yükleniyor...</div>
        </section>

        <section class="gallery">
            <!-- Fotoğraflar buraya gelecek -->
            <img src="img1.jpg" alt="Biz">
            <img src="img2.jpg" alt="Biz">
            <img src="img3.jpg" alt="Biz">
            <img src="img4.jpg" alt="Biz">
            <img src="img5.jpg" alt="Biz">
        </section>

        <section class="proposal">
            <h2>Hüseyin diyor ki...</h2>
            <p>Sude, hayatımın geri kalanında her sabah seninle uyanmaya "EVET" der misin?</p>
            <button class="btn-yes" onclick="celebrate()">EVET!</button>
        </section>
    </div>

    <script>
        function checkPass() {
            const pass = document.getElementById('pass').value;
            if(pass === "120126") {
                document.getElementById('login-screen').style.display = 'none';
                document.getElementById('main-content').style.display = 'block';
                document.getElementById('bgMusic').play();
                startApp();
            } else { alert("Yanlış tarih aşkım!"); }
        }

        function startApp() {
            // Yazı Efekti
            const text = "Seni Çok Seviyorum Sude...";
            let i = 0;
            function type() {
                if(i < text.length) {
                    document.getElementById('typing-text').innerHTML += text.charAt(i);
                    i++; setTimeout(type, 150);
                }
            }
            type();

            // Sayaç (12.01.2026 başlangıç varsayıldı)
            const startDate = new Date("2026-01-12T00:00:00").getTime();
            setInterval(() => {
                const now = new Date().getTime();
                const diff = now - startDate;
                const days = Math.floor(diff / (1000 * 60 * 60 * 24));
                const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                document.getElementById('timer').innerHTML = `${days} Gün, ${hours} Saat...`;
            }, 1000);

            // Uçan Kalpler
            setInterval(() => {
                const heart = document.createElement("div");
                heart.innerHTML = "❤️";
                heart.className = "heart";
                heart.style.left = Math.random() * 100 + "vw";
                heart.style.fontSize = Math.random() * 20 + 10 + "px";
                document.body.appendChild(heart);
                setTimeout(() => heart.remove(), 4000);
            }, 500);
        }

        function celebrate() {
            alert("Dünyanın en mutlu erkeği yaptın beni! Seni seviyorum!");
        }
    </script>
</body>
</html>
